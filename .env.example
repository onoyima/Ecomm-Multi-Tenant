
# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/shopdrop

# ─── Auth ────────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-session-key-change-in-production
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Paystack ────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ─── Mobile (Expo) ───────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://your-replit-domain.replit.app/api
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Shipping ────────────────────────────────────────────────
SENDBOX_API_KEY=your-sendbox-api-key
SENDBOX_API_URL=https://sandbox.sendbox.co/shipping

# ─── Object Storage ──────────────────────────────────────────
STORAGE_BUCKET=shopdrop-assets
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
